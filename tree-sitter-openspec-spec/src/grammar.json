{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "openspec_spec",
  "word": "word",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "delta_section"
          },
          {
            "type": "SYMBOL",
            "name": "requirement"
          },
          {
            "type": "SYMBOL",
            "name": "title"
          }
        ]
      }
    },
    "title": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": " [^\\n]+"
          }
        ]
      }
    },
    "delta_section": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "delta_header"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "requirement"
            }
          }
        ]
      }
    },
    "delta_header": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "## "
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "ADDED"
              },
              {
                "type": "STRING",
                "value": "MODIFIED"
              },
              {
                "type": "STRING",
                "value": "REMOVED"
              },
              {
                "type": "STRING",
                "value": "RENAMED"
              }
            ]
          },
          {
            "type": "STRING",
            "value": " Requirements"
          }
        ]
      }
    },
    "requirement": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "### Requirement:"
          },
          {
            "type": "SYMBOL",
            "name": "requirement_name"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "requirement_body"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "scenario"
            }
          }
        ]
      }
    },
    "requirement_name": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "requirement_body": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "keyword"
            },
            {
              "type": "SYMBOL",
              "name": "word"
            },
            {
              "type": "SYMBOL",
              "name": "_punctuation"
            }
          ]
        }
      }
    },
    "keyword": {
      "type": "PREC",
      "value": 2,
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "SHALL"
              },
              {
                "type": "STRING",
                "value": "NOT"
              }
            ]
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "MUST"
              },
              {
                "type": "STRING",
                "value": "NOT"
              }
            ]
          },
          {
            "type": "STRING",
            "value": "SHALL"
          },
          {
            "type": "STRING",
            "value": "MUST"
          }
        ]
      }
    },
    "word": {
      "type": "PATTERN",
      "value": "[a-zA-Z][a-zA-Z0-9_-]*"
    },
    "_punctuation": {
      "type": "PATTERN",
      "value": "[^a-zA-Z\\s#][^\\s#]*"
    },
    "scenario": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#### Scenario:"
          },
          {
            "type": "SYMBOL",
            "name": "scenario_name"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "condition"
                },
                {
                  "type": "SYMBOL",
                  "name": "assertion"
                },
                {
                  "type": "SYMBOL",
                  "name": "continuation"
                }
              ]
            }
          }
        ]
      }
    },
    "scenario_name": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "condition": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_bold_marker"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "WHEN"
          },
          "named": true,
          "value": "condition_keyword"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_bold_end"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "[^\\n]+"
        }
      ]
    },
    "assertion": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_bold_marker"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "THEN"
          },
          "named": true,
          "value": "assertion_keyword"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_bold_end"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "[^\\n]+"
        }
      ]
    },
    "continuation": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_bold_marker"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "AND"
          },
          "named": true,
          "value": "continuation_keyword"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_bold_end"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "[^\\n]+"
        }
      ]
    },
    "_bold_marker": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "-"
          },
          {
            "type": "PATTERN",
            "value": " "
          },
          {
            "type": "STRING",
            "value": "**"
          }
        ]
      }
    },
    "_bold_end": {
      "type": "STRING",
      "value": "**"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}